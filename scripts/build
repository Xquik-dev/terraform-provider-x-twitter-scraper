set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the generated staging module as private.
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/stainless-sdks/x-twitter-scraper-go"

go build -o terraform-provider-x-twitter-scraper
