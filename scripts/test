#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the generated staging module as private.
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/stainless-sdks/x-twitter-scraper-go"

echo "==> Verifying module integrity"
go mod verify

echo "==> Running race-enabled tests"
go test -race ./... "$@"

if [[ "$#" -eq 0 ]]; then
  echo "==> Enforcing statement coverage"
  ./scripts/coverage
  ./scripts/branch-coverage
fi

echo "==> Checking Windows compilation"
CGO_ENABLED=0 GOOS=windows GOARCH=amd64 go test -exec=true ./...
