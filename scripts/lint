#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the generated staging module as private.
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/stainless-sdks/x-twitter-scraper-go"

echo "==> Checking formatting"
unformatted="$(gofmt -s -l .)"
if [[ -n "$unformatted" ]]; then
  echo "The following files need gofmt -s:" >&2
  echo "$unformatted" >&2
  exit 1
fi

echo "==> Checking module metadata"
go mod tidy -diff

echo "==> Running Go vet"
go vet ./...

echo "==> Running Go build"
go build ./...

echo "==> Checking tests compile"
go test -run='^$' ./...
