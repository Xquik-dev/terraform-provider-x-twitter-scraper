#!/usr/bin/env bash

set -euo pipefail

cd -- "$(dirname -- "$0")/.."

for file in .goreleaser.yml terraform-registry-manifest.json .github/workflows/publish-release.yml; do
  if [[ ! -f "$file" ]]; then
    echo "Missing required release file: $file" >&2
    exit 1
  fi
done

go run github.com/goreleaser/goreleaser/v2@v2.17.0 check

jq -e '.version == 1 and (.metadata.protocol_versions | index("6.0") != null)' terraform-registry-manifest.json >/dev/null
grep -Fq 'artifacts: checksum' .goreleaser.yml
grep -Fq '{{ .Env.GPG_FINGERPRINT }}' .goreleaser.yml
grep -Fq 'environment: release' .github/workflows/publish-release.yml
grep -Fq 'secrets.X_TWITTER_SCRAPER_GPG_SIGNING_KEY' .github/workflows/publish-release.yml
grep -Fq 'secrets.X_TWITTER_SCRAPER_GPG_SIGNING_PASSWORD' .github/workflows/publish-release.yml

echo "Release configuration is valid. Signing secrets remain isolated from pull requests."
